# Public client-bundle variables (inlined by Next.js at build time).
# Safe to commit EXAMPLE values; never commit real secrets.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=loyaltymaster

# -----------------------------------------------------------------------------
# Server-only secrets (read only inside app/api/* route handlers).
# DO NOT prefix with NEXT_PUBLIC_. DO NOT reference these from client code.
# The build will fail if a secret-shaped name is prefixed with NEXT_PUBLIC_.
# Add these to Vercel Env Vars per environment, not to this file.
# -----------------------------------------------------------------------------
# CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@loyaltymaster
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLERK_SECRET_KEY=
# DATABASE_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=sendPUSH <onboarding@resend.dev>
# TRIAL_SIGNUP_TO_EMAIL=admin@loyaltymaster.com
